/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Tickets {
  ticket_id                                         String                @id(map: "TIckets_pkey") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assigner_id                                       String                @db.Uuid
  watcher_id                                        String?               @db.Uuid
  assignment_date                                   DateTime              @default(dbgenerated("(now() AT TIME ZONE 'utc'::text)")) @db.Timestamptz(6)
  creation_date                                     DateTime              @default(dbgenerated("(now() AT TIME ZONE 'utc'::text)")) @db.Timestamptz(6)
  start_date                                        DateTime?             @db.Timestamptz(6)
  end_date                                          DateTime?             @db.Timestamptz(6)
  deadline_date                                     DateTime              @db.Timestamptz(6)
  name                                              String
  description                                       String?
  status                                            status                @default(PENDING)
  TicketAssigned                                    TicketAssigned[]
  TicketComments                                    TicketComments[]
  TicketHistoryEvents                               TicketHistoryEvents[]
  TicketImages                                      TicketImages[]
  TicketSubtasks_TicketSubtasks_subtask_idToTickets TicketSubtasks[]      @relation("TicketSubtasks_subtask_idToTickets")
  TicketSubtasks_TicketSubtasks_ticket_idToTickets  TicketSubtasks[]      @relation("TicketSubtasks_ticket_idToTickets")
  TicketTags                                        TicketTags[]
  Users_Tickets_assigner_idToUsers                  Users               @relation("Tickets_assigner_idToUsers", fields: [assigner_id], references: [user_id], onDelete: SetNull)
  Users_Tickets_watcher_idToUsers                   Users?                @relation("Tickets_watcher_idToUsers", fields: [watcher_id], references: [user_id])
